{
  "_comment": "Synonym → canonical token. Pre-tag user question before routing: replace each match with `[ROUTE:table]` hint feeding the router. Keys are space-tolerant lowercase patterns; values are pipe-joined candidate tables ranked best→worst.",
  "version": 1,
  "ownership": {
    "_comment": "Possessive markers strongly bias toward tenant-owned MySQL tables.",
    "my":              "rhize_*",
    "mine":            "rhize_*",
    "our":             "rhize_*",
    "i sold":          "rhize_orders",
    "i bought":        "rhize_orders",
    "i added":         "rhize_dataset_main",
    "i removed":       "rhize_dataset_main",
    "my catalog":      "rhize_dataset_main",
    "my brand":        "rhize_brands",
    "my brands":       "rhize_brands",
    "my stock":        "rhize_live_inventory",
    "my inventory":    "rhize_live_inventory",
    "live inventory":  "rhize_live_inventory",
    "units left":      "rhize_live_inventory",
    "stock left":      "rhize_live_inventory",
    "live units of":   "rhize_dataset_main",
    "units of":        "rhize_dataset_main",
    "stock of":        "rhize_dataset_main",
    "quantity of":     "rhize_dataset_main",
    "how much stock":  "rhize_dataset_main",
    "how many units":  "rhize_dataset_main",
    "my orders":       "rhize_orders",
    "my customers":    "rhize_orders",
    "my stores":       "rhize_stores",
    "my partners":     "rhize_stores|rhize_partner_stores",
    "my dispensary":   "rhize_stores",
    "my dispensaries": "rhize_stores",
    "our dispensary":  "rhize_stores",
    "our dispensaries":"rhize_stores",
    "active dispensary":   "rhize_stores",
    "active dispensaries": "rhize_stores",
    "active partner":      "rhize_stores",
    "active partners":     "rhize_stores",
    "my lots":         "rhize_product_lots",
    "my revenue":      "rhize_orders|rhize_dataset_main",
    "my sales":        "rhize_orders"
  },
  "market": {
    "_comment": "Market markers strongly bias toward PG market tables.",
    "market":              "chatbot_mv_market_daily|chatbot_market",
    "the market":          "chatbot_mv_market_daily|chatbot_market",
    "in the market":       "chatbot_mv_market_daily|chatbot_market",
    "market-wide":         "chatbot_mv_market_daily",
    "competitor":          "chatbot_mv_market_daily|chatbot_market",
    "competitors":         "chatbot_mv_market_daily",
    "rival":               "chatbot_mv_market_daily",
    "rivals":              "chatbot_mv_market_daily",
    "other brands":        "chatbot_mv_market_daily",
    "other stores":        "chatbot_mv_market_daily",
    "scraped":             "chatbot_market",
    "dispensary":          "chatbot_mv_market_daily|chatbot_market",
    "dispensaries":        "chatbot_mv_market_daily",
    "listing":             "chatbot_market",
    "listings":            "chatbot_market",
    "sku":                 "chatbot_market",
    "skus":                "chatbot_market"
  },
  "concepts": {
    "orders":              "rhize_orders",
    "wholesale":           "rhize_orders",
    "sale":                "rhize_orders|rhize_dataset_main",
    "sales":               "rhize_orders|rhize_dataset_main",
    "transaction":         "rhize_orders",
    "transactions":        "rhize_orders",
    "invoice":             "rhize_orders",
    "open balance":        "rhize_orders",
    "pending order":       "rhize_orders",
    "stock":               "rhize_live_inventory",
    "in stock":            "rhize_live_inventory",
    "low stock":           "rhize_live_inventory",
    "on hand":             "rhize_live_inventory",
    "remaining":           "rhize_live_inventory",
    "lot":                 "rhize_product_lots",
    "lots":                "rhize_product_lots",
    "expiring":            "rhize_product_lots",
    "expiration":          "rhize_product_lots",
    "potency":             "rhize_product_lots|chatbot_market",
    "thc of lot":          "rhize_product_lots",
    "genetics":            "rhize_strain_info",
    "breeder":             "rhize_strain_info",
    "flavor":              "rhize_strain_info",
    "effect":              "rhize_strain_info",
    "follow up":           "rhize_sales_actions",
    "outreach":            "rhize_sales_actions",
    "crm":                 "rhize_sales_actions",
    "action queue":        "rhize_sales_actions",
    "partner store":       "rhize_stores",
    "partner stores":      "rhize_stores",
    "retail account":      "rhize_stores",
    "retailer":            "rhize_stores|chatbot_mv_market_daily",
    "store i sell":        "rhize_stores",
    "tier":                "rhize_stores",
    "added today":         "rhize_dataset_main",
    "removed today":       "rhize_dataset_main",
    "products added":      "rhize_dataset_main",
    "products removed":    "rhize_dataset_main",
    "added to the market": "chatbot_market",
    "removed from the market": "chatbot_market",
    "days on shelf":       "chatbot_market",
    "added": "rhize_dataset_main|chatbot_market",
    "removed": "rhize_dataset_main|chatbot_market",
    "trend":               "chatbot_mv_market_daily|rhize_dataset_main",
    "top brand":           "chatbot_mv_market_daily",
    "top brands":          "chatbot_mv_market_daily",
    "top store":           "chatbot_mv_market_daily",
    "top stores":          "chatbot_mv_market_daily",
    "top customer":        "rhize_orders",
    "top customers":       "rhize_orders",
    "best category":       "chatbot_mv_market_daily",
    "best categories":     "chatbot_mv_market_daily",
    "market share":        "chatbot_mv_market_daily",
    "average price":       "chatbot_market|rhize_dataset_main",
    "avg price":           "chatbot_market|rhize_dataset_main",
    "price under":         "chatbot_market",
    "high thc":            "chatbot_market",
    "premium":             "chatbot_market",
    "cheap":               "chatbot_market"
  },
  "tie_breakers": {
    "_comment": "If both ownership and market signals present, ownership wins UNLESS market phrase contains 'in the market' / 'market-wide' / 'competitor' explicitly.",
    "rules": [
      "ownership signal + no explicit market phrase → MySQL rhize_*",
      "explicit market phrase ('in the market', 'market-wide', 'competitor', 'other brands') → PG chatbot_*",
      "neither signal + ranking/aggregate question → chatbot_mv_market_daily (default market)",
      "neither signal + product detail question → chatbot_market"
    ]
  }
}
