# Read-only Postgres role for the chatbot (Gate A). MUST be separate from any
# app read-write role. Tenant/state isolation depends on RLS on this role.
DATABASE_URL_RO=postgres://chatbot_ro:CHANGEME@localhost:5432/rhize_intel

# OpenAI-compatible LLM endpoint. Default = local Ollama.
CHATBOT_LLM_BASE_URL=http://localhost:11434/v1
CHATBOT_LLM_MODEL=qwen2.5-coder:1.5b
CHATBOT_LLM_API_KEY=ollama
CHATBOT_LLM_TIMEOUT_MS=55000

# Few-shot retrieval (v1 static — top-K from examples.json).
CHATBOT_TOP_K=4

# Schema-RAG: embedding model used to embed the question + schema definitions.
# nomic-embed-text emits 768-dim vectors; matches chatbot_schema_embeddings.
CHATBOT_EMBED_MODEL=nomic-embed-text
CHATBOT_EMBED_TIMEOUT_MS=8000
# How many schema chunks to retrieve per request.
CHATBOT_SCHEMA_TOP_K=8

# Gate D defaults.
CHATBOT_ROW_LIMIT=500
CHATBOT_STATEMENT_TIMEOUT_MS=5000

# Server.
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
